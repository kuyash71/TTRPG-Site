generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  USER
  GM
  ADMIN
}

enum SessionStatus {
  OPEN
  ACTIVE
  CLOSED
}

enum ChatChannel {
  IC
  OOC
}

enum StatType {
  BASE
  DERIVED
  RESOURCE
}

enum SkillNodeType {
  PASSIVE
  ACTIVE
  SPELL_UNLOCK
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ItemCategory {
  WEAPON
  ARMOR
  CONSUMABLE
  MATERIAL
  QUEST
  MISC
}

enum EquipmentSlot {
  HEAD
  CHEST
  LEGS
  FEET
  MAIN_HAND
  OFF_HAND
  ACCESSORY_1
  ACCESSORY_2
}

enum ItemRarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}

enum SpellTargetType {
  SELF
  SINGLE
  AOE
  LINE
}

// ─── Sprint 1: Users ────────────────────────────────────

model User {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique
  passwordHash  String   @map("password_hash")
  username      String   @unique
  role          Role     @default(USER)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  gmSessions       Session[]        @relation("gm_sessions")
  sessionPlayers   SessionPlayer[]
  createdGamesets  Gameset[]
  chatMessages     ChatMessage[]
  diceRolls        DiceRoll[]
  characters       Character[]
  approvalRequests CharacterApprovalRequest[]

  @@map("users")
}

// ─── Sprint 2: Sessions & Gamesets ──────────────────────

model Gameset {
  id              String   @id @default(uuid()) @db.Uuid
  name            String
  description     String   @default("")
  version         Int      @default(1)
  parentGamesetId String?  @map("parent_gameset_id") @db.Uuid
  isPublished     Boolean  @default(false) @map("is_published")
  createdById     String   @map("created_by") @db.Uuid
  config          Json     @default("{}")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()

  parentGameset   Gameset?  @relation("gameset_versions", fields: [parentGamesetId], references: [id])
  childVersions   Gameset[] @relation("gameset_versions")
  createdBy       User      @relation(fields: [createdById], references: [id])
  sessions        Session[]
  statGroups      StatGroup[]
  statDefinitions StatDefinition[]
  classes         GameClass[]
  subclasses      Subclass[]
  races           Race[]
  skillTreeNodes  SkillTreeNode[]
  itemDefinitions  ItemDefinition[]
  spellDefinitions SpellDefinition[]

  @@map("gamesets")
}

model Session {
  id         String        @id @default(uuid()) @db.Uuid
  inviteCode String        @unique @map("invite_code")
  gmId       String        @map("gm_id") @db.Uuid
  gamesetId  String        @map("gameset_id") @db.Uuid
  name       String
  status     SessionStatus @default(OPEN)
  closedAt   DateTime?     @map("closed_at") @db.Timestamptz()
  createdAt  DateTime      @default(now()) @map("created_at") @db.Timestamptz()

  gm               User            @relation("gm_sessions", fields: [gmId], references: [id])
  gameset          Gameset         @relation(fields: [gamesetId], references: [id])
  players          SessionPlayer[]
  chatMessages     ChatMessage[]
  diceRolls        DiceRoll[]
  characters       Character[]
  approvalRequests CharacterApprovalRequest[]

  @@map("sessions")
}

model SessionPlayer {
  id        String   @id @default(uuid()) @db.Uuid
  sessionId String   @map("session_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  joinedAt  DateTime @default(now()) @map("joined_at") @db.Timestamptz()

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([sessionId, userId])
  @@map("session_players")
}

// ─── Sprint 3: Chat & Dice ──────────────────────────────

model ChatMessage {
  id        String      @id @default(uuid()) @db.Uuid
  sessionId String      @map("session_id") @db.Uuid
  userId    String      @map("user_id") @db.Uuid
  channel   ChatChannel @default(OOC)
  content   String
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz()

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@index([sessionId, createdAt])
  @@map("chat_messages")
}

model DiceRoll {
  id         String   @id @default(uuid()) @db.Uuid
  sessionId  String   @map("session_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  notation   String
  results    Json
  total      Int
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@index([sessionId, createdAt])
  @@map("dice_rolls")
}

// ─── Sprint 4: Characters ───────────────────────────────

model Character {
  id          String   @id @default(uuid()) @db.Uuid
  sessionId   String   @map("session_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  gamesetId   String?  @map("gameset_id") @db.Uuid
  classId     String?  @map("class_id") @db.Uuid
  raceId      String?  @map("race_id") @db.Uuid
  name        String
  avatarUrl   String?  @map("avatar_url")
  level       Int      @default(1)
  skillPoints Int      @default(0) @map("skill_points")
  publicData  Json     @default("{}") @map("public_data")
  privateData Json     @default("{}") @map("private_data")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  session      Session              @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user         User                 @relation(fields: [userId], references: [id])
  class        GameClass?           @relation(fields: [classId], references: [id])
  race         Race?                @relation(fields: [raceId], references: [id])
  stats        CharacterStat[]
  wallet       CharacterWallet?
  skillUnlocks CharacterSkillUnlock[]
  inventoryItems CharacterInventoryItem[]
  spells         CharacterSpell[]

  @@unique([sessionId, userId])
  @@map("characters")
}

model CharacterStat {
  id           String  @id @default(uuid()) @db.Uuid
  characterId  String  @map("character_id") @db.Uuid
  name         String
  baseValue    Int     @default(0) @map("base_value")
  currentValue Int     @default(0) @map("current_value")
  maxValue     Int?    @map("max_value")
  isPublic     Boolean @default(true) @map("is_public")

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, name])
  @@map("character_stats")
}

model CharacterWallet {
  id          String @id @default(uuid()) @db.Uuid
  characterId String @unique @map("character_id") @db.Uuid
  gold        Int    @default(0)
  silver      Int    @default(0)
  copper      Int    @default(0)

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@map("character_wallets")
}

// ─── Sprint 5: Gameset Ruleset + Skill Tree ──────────────

model StatGroup {
  id        String @id @default(uuid()) @db.Uuid
  gamesetId String @map("gameset_id") @db.Uuid
  name      String
  icon      String @default("")
  sortOrder Int    @default(0) @map("sort_order")

  gameset     Gameset          @relation(fields: [gamesetId], references: [id], onDelete: Cascade)
  definitions StatDefinition[]

  @@map("stat_groups")
}

model StatDefinition {
  id        String   @id @default(uuid()) @db.Uuid
  gamesetId String   @map("gameset_id") @db.Uuid
  groupId   String   @map("group_id") @db.Uuid
  key       String
  label     String
  type      StatType
  formula   Json?
  isPublic  Boolean  @default(true) @map("is_public")
  maxVal    Int?     @map("max_val")
  sortOrder Int      @default(0) @map("sort_order")

  gameset Gameset  @relation(fields: [gamesetId], references: [id], onDelete: Cascade)
  group   StatGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([gamesetId, key])
  @@map("stat_definitions")
}

model GameClass {
  id          String  @id @default(uuid()) @db.Uuid
  gamesetId   String  @map("gameset_id") @db.Uuid
  name        String
  description String  @default("")
  hitDie      Int     @default(8) @map("hit_die")
  iconUrl     String? @map("icon_url")

  gameset    Gameset         @relation(fields: [gamesetId], references: [id], onDelete: Cascade)
  subclasses Subclass[]
  characters Character[]
  skillNodes SkillTreeNode[]

  @@map("classes")
}

model Subclass {
  id          String @id @default(uuid()) @db.Uuid
  classId     String @map("class_id") @db.Uuid
  gamesetId   String @map("gameset_id") @db.Uuid
  name        String
  description String @default("")
  unlockLevel Int    @default(3) @map("unlock_level")

  parentClass GameClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  gameset     Gameset   @relation(fields: [gamesetId], references: [id], onDelete: Cascade)

  @@map("subclasses")
}

model Race {
  id           String  @id @default(uuid()) @db.Uuid
  gamesetId    String  @map("gameset_id") @db.Uuid
  name         String
  description  String  @default("")
  racialTraits Json    @default("[]") @map("racial_traits")
  iconUrl      String? @map("icon_url")

  gameset    Gameset     @relation(fields: [gamesetId], references: [id], onDelete: Cascade)
  characters Character[]

  @@map("races")
}

model SkillTreeNode {
  id                  String        @id @default(uuid()) @db.Uuid
  gamesetId           String        @map("gameset_id") @db.Uuid
  classId             String?       @map("class_id") @db.Uuid
  name                String
  description         String        @default("")
  nodeType            SkillNodeType @default(PASSIVE) @map("node_type")
  maxLevel            Int           @default(1) @map("max_level")
  costPerLevel        Int           @default(1) @map("cost_per_level")
  unlockLevel         Int           @default(1) @map("unlock_level")
  prerequisites       String[]      @db.Uuid
  statBonusesPerLevel Json          @default("{}") @map("stat_bonuses_per_level")
  effect              Json?
  posX                Float         @default(0) @map("pos_x")
  posY                Float         @default(0) @map("pos_y")
  spellDefinitionId   String?       @map("spell_definition_id") @db.Uuid

  gameset          Gameset              @relation(fields: [gamesetId], references: [id], onDelete: Cascade)
  class            GameClass?           @relation(fields: [classId], references: [id], onDelete: Cascade)
  spellDefinition  SpellDefinition?     @relation("spell_unlock_link", fields: [spellDefinitionId], references: [id], onDelete: SetNull)
  characterUnlocks CharacterSkillUnlock[]

  @@map("skill_tree_nodes")
}

model CharacterSkillUnlock {
  id           String   @id @default(uuid()) @db.Uuid
  characterId  String   @map("character_id") @db.Uuid
  nodeId       String   @map("node_id") @db.Uuid
  currentLevel Int      @default(1) @map("current_level")
  unlockedAt   DateTime @default(now()) @map("unlocked_at") @db.Timestamptz()

  character Character     @relation(fields: [characterId], references: [id], onDelete: Cascade)
  node      SkillTreeNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@unique([characterId, nodeId])
  @@map("character_skill_unlocks")
}

model CharacterApprovalRequest {
  id          String         @id @default(uuid()) @db.Uuid
  sessionId   String         @map("session_id") @db.Uuid
  playerId    String         @map("player_id") @db.Uuid
  status      ApprovalStatus @default(PENDING)
  snapshot    Json
  gmComment   String?        @map("gm_comment")
  submittedAt DateTime       @default(now()) @map("submitted_at") @db.Timestamptz()
  reviewedAt  DateTime?      @map("reviewed_at") @db.Timestamptz()

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  player  User    @relation(fields: [playerId], references: [id])

  @@map("character_approval_requests")
}

// ─── Sprint 6: Inventory + Items ─────────────────────────

model ItemDefinition {
  id            String         @id @default(uuid()) @db.Uuid
  gamesetId     String         @map("gameset_id") @db.Uuid
  name          String
  description   String         @default("")
  category      ItemCategory   @default(MISC)
  gridWidth     Int            @default(1) @map("grid_width")
  gridHeight    Int            @default(1) @map("grid_height")
  equipmentSlot EquipmentSlot? @map("equipment_slot")
  statBonuses   Json           @default("{}") @map("stat_bonuses")
  stackable     Boolean        @default(false)
  maxStack      Int            @default(1) @map("max_stack")
  rarity        ItemRarity     @default(COMMON)
  iconUrl       String?        @map("icon_url")

  gameset        Gameset                 @relation(fields: [gamesetId], references: [id], onDelete: Cascade)
  inventoryItems CharacterInventoryItem[]

  @@map("item_definitions")
}

model CharacterInventoryItem {
  id               String         @id @default(uuid()) @db.Uuid
  characterId      String         @map("character_id") @db.Uuid
  itemDefinitionId String         @map("item_definition_id") @db.Uuid
  posX             Int            @default(0) @map("pos_x")
  posY             Int            @default(0) @map("pos_y")
  quantity         Int            @default(1)
  isEquipped       Boolean        @default(false) @map("is_equipped")
  equippedSlot     EquipmentSlot? @map("equipped_slot")

  character      Character      @relation(fields: [characterId], references: [id], onDelete: Cascade)
  itemDefinition ItemDefinition @relation(fields: [itemDefinitionId], references: [id], onDelete: Cascade)

  @@map("character_inventory_items")
}

// ─── Sprint 7: Spell System ─────────────────────────────

model SpellDefinition {
  id            String          @id @default(uuid()) @db.Uuid
  gamesetId     String          @map("gameset_id") @db.Uuid
  name          String
  description   String          @default("")
  manaCost      Int             @default(0) @map("mana_cost")
  cooldown      Int             @default(0)
  range         Int             @default(0)
  targetType    SpellTargetType @default(SINGLE) @map("target_type")
  effects       Json            @default("[]")
  iconUrl       String?         @map("icon_url")
  requiredLevel Int             @default(1) @map("required_level")

  gameset         Gameset          @relation(fields: [gamesetId], references: [id], onDelete: Cascade)
  characterSpells CharacterSpell[]
  skillTreeNodes  SkillTreeNode[]  @relation("spell_unlock_link")

  @@map("spell_definitions")
}

model CharacterSpell {
  id                String  @id @default(uuid()) @db.Uuid
  characterId       String  @map("character_id") @db.Uuid
  spellDefinitionId String  @map("spell_definition_id") @db.Uuid
  slotIndex         Int?    @map("slot_index")

  character       Character       @relation(fields: [characterId], references: [id], onDelete: Cascade)
  spellDefinition SpellDefinition @relation(fields: [spellDefinitionId], references: [id], onDelete: Cascade)

  @@unique([characterId, spellDefinitionId])
  @@map("character_spells")
}
