generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  USER
  GM
  ADMIN
}

enum SessionStatus {
  OPEN
  ACTIVE
  CLOSING
  CLOSED
}

enum ChatChannel {
  IC
  OOC
}

// ─── Sprint 1: Users ────────────────────────────────────

model User {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique
  passwordHash  String   @map("password_hash")
  username      String   @unique
  role          Role     @default(USER)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  gmSessions     Session[]        @relation("gm_sessions")
  sessionPlayers SessionPlayer[]
  createdGamesets Gameset[]
  chatMessages   ChatMessage[]
  diceRolls      DiceRoll[]
  characters     Character[]

  @@map("users")
}

// ─── Sprint 2: Sessions & Gamesets ──────────────────────

model Gameset {
  id              String   @id @default(uuid()) @db.Uuid
  name            String
  description     String   @default("")
  version         Int      @default(1)
  parentGamesetId String?  @map("parent_gameset_id") @db.Uuid
  isPublished     Boolean  @default(false) @map("is_published")
  createdById     String   @map("created_by") @db.Uuid
  config          Json     @default("{}")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()

  parentGameset   Gameset?  @relation("gameset_versions", fields: [parentGamesetId], references: [id])
  childVersions   Gameset[] @relation("gameset_versions")
  createdBy       User      @relation(fields: [createdById], references: [id])
  sessions        Session[]

  @@map("gamesets")
}

model Session {
  id         String        @id @default(uuid()) @db.Uuid
  inviteCode String        @unique @map("invite_code")
  gmId       String        @map("gm_id") @db.Uuid
  gamesetId  String        @map("gameset_id") @db.Uuid
  name       String
  status     SessionStatus @default(OPEN)
  closedAt   DateTime?     @map("closed_at") @db.Timestamptz()
  createdAt  DateTime      @default(now()) @map("created_at") @db.Timestamptz()

  gm           User            @relation("gm_sessions", fields: [gmId], references: [id])
  gameset      Gameset         @relation(fields: [gamesetId], references: [id])
  players      SessionPlayer[]
  chatMessages ChatMessage[]
  diceRolls    DiceRoll[]
  characters   Character[]

  @@map("sessions")
}

model SessionPlayer {
  id        String   @id @default(uuid()) @db.Uuid
  sessionId String   @map("session_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  joinedAt  DateTime @default(now()) @map("joined_at") @db.Timestamptz()

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([sessionId, userId])
  @@map("session_players")
}

// ─── Sprint 3: Chat & Dice ──────────────────────────────

model ChatMessage {
  id        String      @id @default(uuid()) @db.Uuid
  sessionId String      @map("session_id") @db.Uuid
  userId    String      @map("user_id") @db.Uuid
  channel   ChatChannel @default(OOC)
  content   String
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz()

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@index([sessionId, createdAt])
  @@map("chat_messages")
}

model DiceRoll {
  id         String   @id @default(uuid()) @db.Uuid
  sessionId  String   @map("session_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  notation   String
  results    Json
  total      Int
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@index([sessionId, createdAt])
  @@map("dice_rolls")
}

// ─── Sprint 4: Characters ───────────────────────────────

model Character {
  id         String   @id @default(uuid()) @db.Uuid
  sessionId  String   @map("session_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  name       String
  avatarUrl  String?  @map("avatar_url")
  publicData Json     @default("{}") @map("public_data")
  privateData Json    @default("{}") @map("private_data")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  session Session        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id])
  stats   CharacterStat[]
  wallet  CharacterWallet?

  @@unique([sessionId, userId])
  @@map("characters")
}

model CharacterStat {
  id           String  @id @default(uuid()) @db.Uuid
  characterId  String  @map("character_id") @db.Uuid
  name         String
  baseValue    Int     @default(0) @map("base_value")
  currentValue Int     @default(0) @map("current_value")
  maxValue     Int?    @map("max_value")
  isPublic     Boolean @default(true) @map("is_public")

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, name])
  @@map("character_stats")
}

model CharacterWallet {
  id          String @id @default(uuid()) @db.Uuid
  characterId String @unique @map("character_id") @db.Uuid
  gold        Int    @default(0)
  silver      Int    @default(0)
  copper      Int    @default(0)

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@map("character_wallets")
}
